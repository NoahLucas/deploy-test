# Backend
OPENAI_API_KEY=<SECRET>
OPENAI_MODEL=gpt-5
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy

# Security
ADMIN_TOKEN=replace-with-long-random-token
RELAY_SHARED_SECRET=replace-with-32-byte-random-secret
ENFORCE_APPLE_CONTEXT=false
APPLE_ALLOWED_BUNDLE_IDS=com.noahlucas.relay
REQUIRE_APPLE_ATTESTATION_TOKEN=false
APPLE_IDENTITY_AUDIENCE=com.noahlucas.lab
APPLE_IDENTITY_ISSUER=https://appleid.apple.com
APPLE_IDENTITY_JWKS_URL=https://appleid.apple.com/auth/keys
APPLE_APP_ATTEST_MODE=basic
APP_ATTEST_CHALLENGE_TTL_SECONDS=300
SQUARESPACE_WEBHOOK_SECRET=replace-with-webhook-shared-secret
SQUARESPACE_WEBHOOK_ENFORCE_SIGNATURE=true

# Infrastructure
DATABASE_PATH=backend/data/signals.db
CORS_ORIGINS=http://localhost:8000,https://noahlucas.com
RENDER_PROD_DEPLOY_HOOK_URL=
RENDER_PROD_DEPLOY_HOOK_TOKEN=
